{
  "name": "@specforge/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "pnpm clean && vitest run",
    "test:watch": "vitest",
    "db:migrate": "node-pg-migrate --migrations-dir migrations",
    "db:migrate:create": "node-pg-migrate create",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@specforge/config-typescript": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@trpc/server": "^11.18.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
