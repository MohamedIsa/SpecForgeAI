{
  "name": "@specforge/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "pnpm clean && vitest run",
    "test:smoke": "pnpm clean && vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "db:migrate": "node-pg-migrate --migrations-dir migrations up",
    "db:migrate:create": "node-pg-migrate create",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.973.15",
    "@specforge/config-typescript": "workspace:*",
    "@trpc/client": "^11.18.0",
    "@types/node": "^26.1.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@trpc/server": "^11.18.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "mammoth": "^1.12.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
