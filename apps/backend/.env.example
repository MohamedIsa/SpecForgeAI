# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/specforge

# Or use individual params:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=specforge
# DB_USER=postgres
# DB_PASSWORD=postgres

# Pool Configuration
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Server
PORT=3001
